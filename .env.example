# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=gnice_user
DB_PASSWORD=changeme
DB_NAME=gnice_db
DB_SSLMODE=disable

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
GIN_MODE=debug

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=change_this_to_a_strong_secret_at_least_32_chars

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get your key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Use 'onboarding@resend.dev' for quick testing without a verified domain
EMAIL_FROM=G-Nice <noreply@yourdomain.com>

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5173

# ── S3 Media Storage ─────────────────────────────────────────────────────────
# Create an IAM user with the policy in docs/aws-setup.md and paste its keys here.
# Access Key ID — found in IAM Console → Users → Security credentials
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# Secret Access Key — shown only once at creation time; store it securely
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS region where the S3 bucket lives
AWS_REGION=af-south-1
# Name of the S3 bucket (must already exist — see docs/aws-setup.md)
AWS_S3_BUCKET=g-nice-media
