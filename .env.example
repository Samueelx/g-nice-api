# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=gnice_user
DB_PASSWORD=changeme
DB_NAME=gnice_db
DB_SSLMODE=disable

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
GIN_MODE=debug

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=change_this_to_a_strong_secret_at_least_32_chars

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5173
